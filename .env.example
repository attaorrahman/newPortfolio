# Supabase (https://supabase.com — free tier)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend (https://resend.com — free 3,000/mo)
RESEND_API_KEY=re_YOUR_KEY
# From-address must be on a domain you've verified in Resend.
# For initial testing you can use 'onboarding@resend.dev'.
RESEND_FROM="Atta Portfolio <onboarding@resend.dev>"

# Owner inbox (where contact + meeting notifications are sent)
OWNER_EMAIL=ar416.official@gmail.com

# Admin auth — generate hash with: node scripts/hash-password.mjs <password>
ADMIN_PASSWORD_HASH=
# Random 32+ char string. Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Public site origin (used in emails, OG, schema.org)
NEXT_PUBLIC_SITE_URL=https://attaurrahman.dev
